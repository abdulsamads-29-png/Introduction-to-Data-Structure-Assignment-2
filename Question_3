#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;

void push(int x) {
    stack[++top] = x;
}

int pop() {
    return stack[top--];
}

int peek() {
    return stack[top];
}

int main() {
    int arr[MAX], n, i, next;

    scanf("%d", &n);
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    push(arr[0]);

    for(i = 1; i < n; i++) {
        next = arr[i];

        while(top != -1 && peek() < next)
            printf("%d -> %d\n", pop(), next);

        push(next);
    }

    while(top != -1)
        printf("%d -> -1\n", pop());

    return 0;
}
