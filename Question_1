#include <stdio.h>
#include <string.h>

#define MAX 100

char stack[MAX];
int top = -1;

void push(char c) {
    stack[++top] = c;
}

char pop() {
    return stack[top--];
}

int main() {
    char str[MAX];
    int i;

    scanf("%s", str);

    for(i = 0; str[i] != '\0'; i++)
        push(str[i]);

    for(i = 0; i < strlen(str); i++)
        str[i] = pop();

    printf("%s", str);

    return 0;
}
